# --- App ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173,http://localhost:8081

# --- MongoDB ---
# Local docker:   mongodb://localhost:27017/publication_trend
# Atlas (prod):   mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/publication_trend
MONGODB_URI=mongodb://localhost:27017/publication_trend

# --- Redis (BullMQ + cache) ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Gemini AI ---
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-3.5-flash
GEMINI_MODEL_DEEP=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=768

# --- External academic APIs ---
# OpenAlex asks (does not require) a polite-pool email
OPENALEX_MAILTO=hoangtira@gmail.com
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_MAILTO=hoangtira@gmail.com

# --- Sync schedule ---
SYNC_CRON=0 2 * * *           # daily at 02:00
SYNC_BATCH_SIZE=200
SYNC_MAX_PAGES_PER_RUN=10
